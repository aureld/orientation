# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/orientation?schema=public"

# ── Auth.js ──────────────────────────────────────────────
# REQUIRED in staging/production. Generate with:
#   openssl rand -base64 32
AUTH_SECRET=
AUTH_URL="https://your-domain.example.com"

# ── Cron / ingestion ─────────────────────────────────────
# Bearer token for POST /api/cron/ingest. Generate with:
#   openssl rand -base64 32
CRON_SECRET=

# ── Embeddings (optional) ────────────────────────────────
# OLLAMA_URL="http://localhost:11434"
# OPENAI_API_KEY=
